		"typescript": "~6.0.3"
	},
	"scripts": {
		"start": "expo start",
		"android": "expo start --android",
		"ios": "expo start --ios",
		"web": "expo start --web",
		"lint": "expo lint",
		"format": "biome format --write",
		"typecheck": "tsc --noEmit",
		"postinstall": "simple-git-hooks"
	},
	"simple-git-hooks": {
		"pre-commit": "npx lint-staged"
	},
	"lint-staged": {
		"*.{ts,tsx,js,json,css,mjs}": [
			"biome check --linter-enabled=false --write"
