{
	"expo": {
		"name": "duolingo-clone",
		"slug": "duolingo-clone",
		"version": "1.0.0",
		"orientation": "portrait",
		"icon": "./assets/images/icon.png",
		"scheme": "duolingoclone",
		"userInterfaceStyle": "automatic",
		"ios": {
			"icon": "./assets/images/app-icon.png",
			"bundleIdentifier": "com.bns2.duolingo-clone",
			"infoPlist": {
				"NSCameraUsageDescription": "Lingua uses camera access for AI teacher video lessons.",
				"NSMicrophoneUsageDescription": "Lingua uses microphone access for live audio lessons."
			}
		},
		"android": {
			"adaptiveIcon": {
				"backgroundColor": "#E6F4FE",
				"foregroundImage": "./assets/images/android-icon-foreground.png",
				"backgroundImage": "./assets/images/android-icon-background.png",
				"monochromeImage": "./assets/images/android-icon-monochrome.png"
			},
			"predictiveBackGestureEnabled": false,
			"package": "com.bns2.duolingoclone",
			"permissions": ["CAMERA", "RECORD_AUDIO", "MODIFY_AUDIO_SETTINGS", "BLUETOOTH_CONNECT"]
		},
		"web": {
			"output": "server",
			"favicon": "./assets/images/favicon.png"
		},
		"plugins": [
			"expo-router",
			[
				"expo-splash-screen",
				{
					"backgroundColor": "#208AEF",
					"android": {
						"image": "./assets/images/splash-icon.png",
						"imageWidth": 76
					}
				}
			],
			"@clerk/expo",
			"expo-secure-store",
			"@stream-io/video-react-native-sdk",
			[
				"@config-plugins/react-native-webrtc",
				{
					"cameraPermission": "Lingua uses camera access for AI teacher video lessons.",
					"microphonePermission": "Lingua uses microphone access for live audio lessons."
				}
			],
			[
				"expo-build-properties",
				{
					"android": {
						"minSdkVersion": 24
					}
				}
			]
		],
		"experiments": {
			"typedRoutes": true,
			"reactCompiler": true
		}
	}
}
